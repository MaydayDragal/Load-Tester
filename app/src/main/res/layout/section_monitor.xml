<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Connection -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <View
                    android:id="@+id/connDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/dot"
                    android:backgroundTint="@color/value_red" />

                <TextView
                    android:id="@+id/connStatusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="@string/disconnected"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/connButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/scan_connect" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Protection banner -->
        <TextView
            android:id="@+id/warningText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/value_red"
            android:padding="10dp"
            android:text="@string/protection"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Primary readouts -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/ReadoutCell">
                        <TextView style="@style/ReadoutLabel" android:text="@string/voltage" />
                        <TextView android:id="@+id/voltageValue" style="@style/ReadoutValue"
                            android:textColor="@color/value_green" android:text="—" />
                    </LinearLayout>

                    <LinearLayout style="@style/ReadoutCell">
                        <TextView style="@style/ReadoutLabel" android:text="@string/current" />
                        <TextView android:id="@+id/currentValue" style="@style/ReadoutValue"
                            android:textColor="@color/value_amber" android:text="—" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/ReadoutCell">
                        <TextView style="@style/ReadoutLabel" android:text="@string/power" />
                        <TextView android:id="@+id/powerValue" style="@style/ReadoutValue"
                            android:textColor="@color/accent" android:text="—" />
                    </LinearLayout>

                    <LinearLayout style="@style/ReadoutCell">
                        <TextView style="@style/ReadoutLabel" android:text="@string/mode" />
                        <TextView android:id="@+id/modeValue" style="@style/ReadoutValue" android:text="—" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:background="?attr/colorOutline" />

                <TextView
                    android:id="@+id/extraValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:text="" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Controls -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView style="@style/SectionHeader" android:text="@string/mode" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/modeChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:singleSelection="true"
                    app:selectionRequired="false">

                    <com.google.android.material.chip.Chip android:id="@+id/chipCc"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CC" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipCv"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CV" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipCr"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CR" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipCp"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CP" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipCap"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="CAP" />
                    <com.google.android.material.chip.Chip android:id="@+id/chipDcr"
                        style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="DCR" />
                </com.google.android.material.chip.ChipGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/setpointLayout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/setpoint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/setpointInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/setSetpointButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/set" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loadToggle"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/load_on"
                    android:textSize="16sp"
                    app:backgroundTint="@color/value_green" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lockButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/lock" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Live waveform -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView style="@style/SectionHeader"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:text="@string/waveform" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wavePauseButton"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_pause" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/waveRecordButton"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_record" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/waveExportButton"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_download" />
                </LinearLayout>

                <TextView
                    android:id="@+id/waveLegend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/waveform_legend"
                    android:textSize="12sp" />

                <com.loadtester.el15.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/waveStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:text="—" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Packet inspector -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView style="@style/SectionHeader"
                        android:layout_width="0dp" android:layout_weight="1"
                        android:text="@string/packet_inspector" />

                    <TextView
                        android:id="@+id/packetCrc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="CRC —"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/packetHex"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:text="—" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
