<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_bg"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/session_results_title"
        app:titleTextColor="?attr/colorOnSurface"
        app:titleTextAppearance="@style/ToolbarTitle" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="13dp">

            <!-- Headline -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/surface" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/typeHeader" style="@style/SectionHeader" android:text="@string/session_results_title" />
                    <TextView android:id="@+id/headlineValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:text="—" android:textColor="@color/accent"
                        android:textSize="30sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                    <TextView android:id="@+id/summaryText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:fontFamily="monospace"
                        android:textColor="@color/muted" android:textSize="13sp" />
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Battery health (capacity tests only) -->
            <com.loadtester.el15.BlueprintFrame
                android:id="@+id/healthFrame"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface" android:padding="16dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView style="@style/SectionHeader" android:text="@string/session_health" />
                    <TextView android:id="@+id/healthGrade"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:fontFamily="sans-serif-condensed"
                        android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:id="@+id/healthText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:fontFamily="monospace"
                        android:textColor="@color/muted" android:textSize="12sp" />
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Test details -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView style="@style/SectionHeader" android:text="@string/rt_details" />
                    <TextView android:id="@+id/metadataText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:fontFamily="monospace"
                        android:textColor="@color/muted" android:textSize="12sp" />
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Tag + notes -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface" android:padding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tagLayout"
                        style="@style/Field" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="@string/record_tag_hint">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/tagInput"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text" android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/notesLayout"
                        style="@style/Field" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:hint="@string/rt_notes_hint">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/notesInput"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:gravity="top" android:inputType="textMultiLine|textCapSentences" android:minLines="2" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Interactive time-series chart -->
            <TextView style="@style/SectionHeader" android:layout_marginTop="14dp" android:layout_marginStart="2dp"
                android:text="@string/chart_title" />
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:background="@color/surface" android:padding="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.loadtester.el15.TimeSeriesChartView android:id="@+id/chart"
                        android:layout_width="match_parent" android:layout_height="300dp" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="@string/session_chart_hint"
                        android:textColor="@color/muted" android:textSize="11sp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="6dp"
                        android:gravity="center_vertical">
                        <com.google.android.material.chip.ChipGroup android:id="@+id/seriesGroup"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            app:chipSpacingHorizontal="6dp" app:chipSpacingVertical="6dp">
                            <com.google.android.material.chip.Chip android:id="@+id/seriesV" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checkable="true" android:text="V" />
                            <com.google.android.material.chip.Chip android:id="@+id/seriesI" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checkable="true" android:text="I" />
                            <com.google.android.material.chip.Chip android:id="@+id/seriesP" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checkable="true" android:text="P" />
                            <com.google.android.material.chip.Chip android:id="@+id/seriesT" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checkable="true" android:text="Temp" />
                        </com.google.android.material.chip.ChipGroup>
                        <com.google.android.material.button.MaterialButton android:id="@+id/resetZoom"
                            style="@style/BtnSecondary" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:minWidth="0dp"
                            android:text="@string/session_reset_zoom" />
                    </LinearLayout>
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Actions -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="13dp" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/printButton"
                    style="@style/BtnPrimary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/rt_print" />
                <com.google.android.material.button.MaterialButton android:id="@+id/shareButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="9dp" android:layout_weight="1" android:text="@string/rt_share" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="9dp" android:layout_marginBottom="8dp" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/csvButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/rt_csv" />
                <com.google.android.material.button.MaterialButton android:id="@+id/saveButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="9dp" android:layout_weight="1" android:text="@string/rt_save_device"
                    app:icon="@drawable/ic_save" app:iconGravity="textStart" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
