<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_bg"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/rt_results_title"
        app:titleTextColor="?attr/colorOnSurface"
        app:titleTextAppearance="@style/ToolbarTitle" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="13dp">

            <!-- Headline -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/surface" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView style="@style/SectionHeader" android:text="@string/rt_circuit_resistance" />
                    <TextView android:id="@+id/resistanceValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:text="—" android:textColor="@color/accent"
                        android:textSize="42sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                    <TextView android:id="@+id/summaryText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:textColor="@color/muted" android:textSize="13sp" />
                    <TextView android:id="@+id/reliabilityText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:textSize="13sp" android:textStyle="bold" android:visibility="gone" />
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Test details -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView style="@style/SectionHeader" android:text="@string/rt_details" />
                    <TextView android:id="@+id/metadataText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:fontFamily="monospace"
                        android:textColor="@color/muted" android:textSize="12sp" />
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Notes -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface" android:padding="14dp">
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/notesLayout"
                    style="@style/Field" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="@string/rt_notes_hint">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/notesInput"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="top" android:inputType="textMultiLine|textCapSentences" android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Interactive chart -->
            <TextView style="@style/SectionHeader" android:layout_marginTop="14dp" android:layout_marginStart="2dp"
                android:text="@string/chart_title" />

            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:background="@color/surface" android:padding="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- View selector -->
                    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <com.google.android.material.chip.ChipGroup android:id="@+id/chartViewGroup"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            app:singleSelection="true" app:selectionRequired="true" app:singleLine="true"
                            app:chipSpacingHorizontal="6dp">
                            <com.google.android.material.chip.Chip android:id="@+id/viewVi" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chart_view_vi" />
                            <com.google.android.material.chip.Chip android:id="@+id/viewTrend" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chart_view_trend" />
                            <com.google.android.material.chip.Chip android:id="@+id/viewAbs" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chart_view_abs" />
                            <com.google.android.material.chip.Chip android:id="@+id/viewRi" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chart_view_ri" />
                            <com.google.android.material.chip.Chip android:id="@+id/viewPi" style="@style/ModeChip"
                                android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chart_view_pi" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <com.loadtester.el15.TestChartView android:id="@+id/chart"
                        android:layout_width="match_parent" android:layout_height="300dp"
                        android:layout_marginTop="8dp" />

                    <!-- Series toggles (trend views) -->
                    <com.google.android.material.chip.ChipGroup android:id="@+id/seriesGroup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="6dp" app:chipSpacingVertical="6dp">
                        <com.google.android.material.chip.Chip android:id="@+id/seriesV" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="V" />
                        <com.google.android.material.chip.Chip android:id="@+id/seriesI" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="I" />
                        <com.google.android.material.chip.Chip android:id="@+id/seriesP" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="P" />
                        <com.google.android.material.chip.Chip android:id="@+id/seriesT" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="Temp" />
                        <com.google.android.material.chip.Chip android:id="@+id/seriesF" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="Fan" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Style toggles -->
                    <com.google.android.material.chip.ChipGroup android:id="@+id/styleGroup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        app:chipSpacingHorizontal="6dp" app:chipSpacingVertical="6dp">
                        <com.google.android.material.chip.Chip android:id="@+id/styleGrid" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="@string/chart_style_grid" />
                        <com.google.android.material.chip.Chip android:id="@+id/styleMarkers" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="@string/chart_style_markers" />
                        <com.google.android.material.chip.Chip android:id="@+id/styleFill" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="@string/chart_style_fill" />
                        <com.google.android.material.chip.Chip android:id="@+id/styleThick" style="@style/ModeChip"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checkable="true" android:text="@string/chart_style_thick" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Data table -->
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="11dp" android:background="@color/surface">
                <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none">
                    <TextView android:id="@+id/dataTable"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="monospace" android:padding="16dp"
                        android:textColor="?attr/colorOnSurface" android:textSize="12sp" />
                </HorizontalScrollView>
            </com.loadtester.el15.BlueprintFrame>

            <!-- Report contents -->
            <TextView style="@style/SectionHeader" android:layout_marginTop="14dp" android:layout_marginStart="2dp"
                android:text="@string/rt_report_contents" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:layout_marginStart="2dp" android:text="@string/rt_report_hint"
                android:textColor="@color/muted" android:textSize="12sp" />
            <com.loadtester.el15.BlueprintFrame
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:background="@color/surface" android:padding="8dp">
                <LinearLayout android:id="@+id/reportItemsContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
            </com.loadtester.el15.BlueprintFrame>

            <!-- Actions -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="13dp" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/printButton"
                    style="@style/BtnPrimary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/rt_print" />
                <com.google.android.material.button.MaterialButton android:id="@+id/shareButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="9dp" android:layout_weight="1" android:text="@string/rt_share" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="9dp" android:layout_marginBottom="8dp" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/csvButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/rt_csv" />
                <com.google.android.material.button.MaterialButton android:id="@+id/saveButton"
                    style="@style/BtnSecondary" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="9dp" android:layout_weight="1" android:text="@string/rt_save_device"
                    app:icon="@drawable/ic_save" app:iconGravity="textStart" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
